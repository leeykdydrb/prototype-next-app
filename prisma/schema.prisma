// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

model User {
  id        String  @id @default(uuid())
  password  String
  email     String  @unique
  name      String
  isSystem  Boolean  @default(false) // 시스템 기본 계정 (삭제 불가)
  isActive  Boolean  @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  profile   Profile?
  role      Role    @relation(fields: [roleId], references: [id])
  roleId    Int

  userPermissions UserPermission[]
}

model Profile {
  id     Int    @id @default(autoincrement())
  bio    String
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique
}

model Dashboard {
  id          Int         @id @default(autoincrement())
  boardName   String
  notice      String
}

model Equipment {
  id        Int       @id @default(autoincrement())
  name      String
  location  String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique // "ADMIN", "MANAGER", "USER" 등
  displayName String  // "관리자", "매니저", "사용자" 등
  description String?
  isSystem    Boolean @default(false) // 시스템 기본 역할 (삭제 불가)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // 관계
  users           User[]
  rolePermissions RolePermission[]
}

// 권한 관리 테이블
model Permission {
  id          Int     @id @default(autoincrement())
  name        String  @unique // "equipment.create", "users.read" 등
  displayName String  // "설비 생성", "사용자 조회" 등
  description String?

  // category    String? // "설비", "사용자", "보고서" 등 - 권한 분류용
  categoryId    Int     // Code 테이블의 id 참조
  category      Code    @relation(fields: [categoryId], references: [id])

  isSystem    Boolean @default(false) // 시스템 기본 권한 (삭제 불가)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // 관계
  rolePermissions RolePermission[]
  userPermissions UserPermission[]
  menuPermissions MenuPermission[]
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId       Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId Int
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
}

model UserPermission {
  id           Int        @id @default(autoincrement())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId Int
  granted      Boolean    @default(true) // true: 권한 부여, false: 권한 제거
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, permissionId])
}

// 메뉴 관리 테이블
model Menu {
  id          Int     @id @default(autoincrement())
  title       String
  titleKey    String
  path        String?
  icon        String?  // 아이콘 이름
  order       Int     @default(0)
  isActive    Boolean @default(true)
  isSystem    Boolean @default(false) // 시스템 기본 메뉴 (삭제 불가)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // 계층 구조
  parentId Int?
  parent   Menu?  @relation("MenuHierarchy", fields: [parentId], references: [id])
  children Menu[] @relation("MenuHierarchy")
  
  // 권한 관계
  menuPermissions MenuPermission[]
}

model MenuPermission {
  id           Int        @id @default(autoincrement())
  menu         Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  menuId       Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId Int
  createdAt    DateTime   @default(now())

  @@unique([menuId, permissionId])
}

// 공통 코드 관리 테이블
model CodeGroup {
  id          Int      @id @default(autoincrement())
  groupCode   String   @unique // "PERMISSION_CATEGORY", "ROLE_TYPE" 등
  groupName   String   // "권한 카테고리", "역할 타입" 등
  description String?
  isActive    Boolean  @default(true)
  isSystem    Boolean  @default(false) // 시스템 기본 코드 그룹 (삭제 불가)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 계층 구조
  parentId    Int?
  parent      CodeGroup?  @relation("CodeGroupHierarchy", fields: [parentId], references: [id])
  children    CodeGroup[] @relation("CodeGroupHierarchy")
  
  // 관계
  codes Code[]
}

model Code {
  id          Int       @id @default(autoincrement())
  group       CodeGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId     Int
  code        String    // "SYSTEM", "USER", "CONTENT" 등
  codeName    String    // "시스템", "사용자", "콘텐츠" 등
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  isSystem    Boolean   @default(false) // 시스템 기본 코드 (삭제 불가)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  permissions Permission[]
  
  @@unique([groupId, code])
}

// 비동기 작업 관리 테이블
model Job {
  id          String   @id @default(uuid())
  type        String   // 작업 타입: "EQUIPMENT_CREATE", "DATA_EXPORT" 등
  status      JobStatus @default(PENDING)
  priority    Int      @default(0) // 우선순위 (높을수록 우선)
  progress    Int      @default(0) // 진행률 (0-100)
  
  // 작업 데이터 및 결과
  inputData   Json?    // 입력 데이터
  result      Json?    // 작업 결과
  error       String?  // 에러 메시지
  
  // 재시도 관련
  retryCount  Int      @default(0) // 재시도 횟수
  maxRetries  Int      @default(3) // 최대 재시도 횟수
  
  // 타임아웃 관련
  timeoutAt   DateTime? // 타임아웃 시간
  startedAt   DateTime? // 작업 시작 시간
  completedAt DateTime? // 작업 완료 시간
  
  // 작업 취소
  cancelledAt DateTime? // 취소 시간
  cancelledBy String?   // 취소한 사용자 ID
  
  // 메타데이터
  createdBy   String?  // 작업 생성한 사용자 ID
  metadata    Json?    // 추가 메타데이터
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([priority, createdAt])
}

enum JobStatus {
  PENDING     // 대기 중
  PROCESSING  // 처리 중
  COMPLETED   // 완료
  FAILED      // 실패
  CANCELLED   // 취소됨
  TIMEOUT     // 타임아웃
}

